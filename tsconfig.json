{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true
    ,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "prisma/**/*.ts"]
}
